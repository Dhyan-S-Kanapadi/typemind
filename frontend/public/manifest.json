{
  "manifest_version": 3,
  "name": "TypeMind",
  "version": "0.1",
  "description": "AI-powered clarity for everything you type",

  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],

  "host_permissions": [
    "http://127.0.0.1:8080/*",
    "http://localhost:8080/*"
  ],
"background": {
  "service_worker": "src/background.js",
  "type": "module"
},

  "content_scripts": [
    {
      "matches": ["https://*/*", "http://*/*"],
      "js": ["src/content/index.jsx"],
      "run_at": "document_end"
    }
  ],

  "action": {
    "default_popup": "index.html"
  }
}