{
  "manifest_version": 3,
  "name": "AI Context Assistant",
  "version": "0.1",
  "description": "AI-powered writing assistant for Gmail, WhatsApp and more",

  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],

  "host_permissions": [
    "https://*/*",
    "http://*/*"
  ],

  "content_scripts": [
    {
      "matches": ["https://*/*", "http://*/*"],
      "js": ["src/content/index.jsx"],
      "run_at": "document_end"
    }
  ],

  "action": {
    "default_popup": "index.html"
  }
}